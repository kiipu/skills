{
  "name": "@kiipu/skills",
  "version": "0.0.8",
  "description": "Kiipu Claude Code skills published as standalone static assets.",
  "license": "MIT",
  "type": "module",
  "files": [
    "skills",
    "README.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./skills/*": "./skills/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "release:patch": "npm version patch --no-git-tag-version",
    "release:minor": "npm version minor --no-git-tag-version",
    "release:major": "npm version major --no-git-tag-version",
    "pack:local": "node scripts/pack-local.mjs",
    "publish:dry-run": "node ../../infra/scripts/prepare-skills-release.mjs && npm publish ../../.release/skills-package --dry-run"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "typescript": "^5.6.3"
  }
}
